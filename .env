# TikHub API 配置
# 注册获取 Token: https://tikhub.io
TIKHUB_API_TOKEN=your_api_token_here
# TIKHUB_API_BASE=https://api.tikhub.dev

# LLM 配置（二选一或配置 provider 指定）
# 通义千问 / 百炼（推荐国内）
DASHSCOPE_API_KEY=sk-1355098646214d2e97912267aa74e225
# DASHSCOPE_MODEL=qwen-plus

# OpenAI 或兼容接口
OPENAI_API_KEY=your_openai_key_here
# OPENAI_BASE_URL=  # 可选
# LLM_MODEL=gpt-4o-mini

# 指定 provider（可选）：dashscope | openai，空则自动检测
# LLM_PROVIDER=dashscope

# Phase 2 工作流（默认开启）
# USE_WORKFLOW=true
# DB_PATH=   # 空则 data/yingxiao.db

# Phase 2 工作流编排（可选）
USE_WORKFLOW=true
# DB_PATH=data/yingxiao.db

# 演示模式：公司演示时设为 true，使用预置 demo 数据，无需 API
DEMO_MODE=true
# DEMO_DATA_PATH=data/raw/demo_tiktok_hot.csv

# Kling 视频生成（营销/电商短视频）- 按可灵官方文档
# 注册: https://klingai.com/global/dev 获取 AccessKey + SecretKey
KLING_ACCESS_KEY=ABnetRDCaMFRgRTfkYFkDpFTy8gddKmC
KLING_SECRET_KEY=TkkaApafLTmNNdfkYhbpNFPKH4anBe8p
# 中国区默认（官方文档）：api-beijing.klingai.com
# KLING_API_BASE=https://api-beijing.klingai.com
# 国际区可选: https://api.klingai.com
# 生成视频保存目录
VIDEO_SAVE_DIR=D:/movie

# 飞书机器人
